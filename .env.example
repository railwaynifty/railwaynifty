# Shared Railway PostgreSQL URL
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# Railway backend only
JWT_SECRET=replace-with-at-least-48-random-characters

# Use the same value in Railway backend and Vercel frontend
INTERNAL_PROXY_KEY=replace-with-at-least-32-random-characters

# One-time initial admin seed. Change/remove password after first login.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMe-Immediately-123!

# Vercel frontend only
BACKEND_URL=https://your-backend.up.railway.app

# Core behavior
SESSION_DAYS=7
APP_DATA_DIR=/app/data
SCHEMA_OPTIONS=options
SCHEMA_FUTURES=futures
SCHEMA_CASH=cash

# Archive temporary ZIP files. Local ZIPs expire automatically.
ARCHIVE_TEMP_DIR=/tmp/nse360_archives
ARCHIVE_LOCAL_TTL_HOURS=6

# Optional automatic Google Drive retention check, run by backend after this IST hour.
ARCHIVE_AUTO_ENABLED=false
ARCHIVE_AUTO_HOUR_IST=21
ARCHIVE_RETENTION_DAYS=30
ARCHIVE_AUTO_PURGE=false
# none = delete only, vacuum = reusable DB space, full = physical file compaction/locking
ARCHIVE_COMPACT_MODE=vacuum

# Google Drive destination folder ID. Required for Drive uploads.
GOOGLE_DRIVE_FOLDER_ID=

# Authentication option A: service account JSON (raw JSON or base64-encoded JSON).
# Prefer a Google Shared Drive folder accessible to this service account.
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# Authentication option B: OAuth credentials for a normal Google Drive account.
# Leave blank when using the service-account option above.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# Viewer audit-log retention in PostgreSQL. Older entries are removed by the backend daily and at startup.
AUDIT_RETENTION_DAYS=90
